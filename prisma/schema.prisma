generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==========================================
// 🧑‍💼 CORE MEMBERSHIP & DASHBOARD ECOSYSTEM
// ==========================================

model User {
  id              Int           @id @default(autoincrement())
  name            String        @default("User")
  email           String        @unique
  password        String
  
  // 🛡️ Synchronized Identity & Vital Statistics Parameters
  placeOfBirth    String?
  dateOfBirth     String?
  maritalStatus   String?
  originCountry   String?       @default("Uganda")
  hostCountry     String?
  domicileStatus  String?
  passportNumber  String?
  gpsLocation     String?
  profession      String?

  // System Relations
  applications    Application[]
  logs            Activity[]
  voipAccount     VoipAccount?
  remittances     RemittanceLog[]
}

model Job {
  id           Int           @id @default(autoincrement())
  title        String
  description  String        @default("")
  applications Application[]
}

model Application {
  id     Int  @id @default(autoincrement())
  userId Int
  jobId  Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Activity {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 📂 Network Registry with Google Maps Coordinate support:
model NetworkRegistry {
  id           Int      @id @default(autoincrement())
  userId       Int?
  fullName     String
  email        String
  phone        String
  country      String
  city         String
  postalCode   String
  fullAddress  String
  latitude     Float?
  longitude    Float?
  sector       String
  businessName String?
  createdAt    DateTime @default(now())
}

// ==========================================
// 🏦 REMITTANCE & SACCO INTEGRATED LEDGER
// ==========================================

model RemittanceLog {
  id                  String             @id @default(uuid())
  senderId            Int                // 🟢 FIXED: Type aligned to match User.id (Int)
  user                User               @relation(fields: [senderId], references: [id], onDelete: Cascade) // 🟢 FIXED: Missing relational map added
  recipientName       String
  recipientAccount    String
  amount              Float
  currency            String             @default("UGX")
  gateway             String             @default("mpesa")
  status              String             @default("PENDING")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // 🔗 Connection Nodes back to SACCO Capital Accounts
  isSaccoDeposit      Boolean            @default(false)
  saccoSubscriptionId String?
  saccoSubscription   SaccoSubscription? @relation(fields: [saccoSubscriptionId], references: [id])

  @@index([senderId])
}

// ==========================================
// 🏛️ B2B INSTITUTIONAL SACCO CORPORATE REGISTRY
// ==========================================

model SaccoInstitution {
  id                 String   @id @default(uuid())
  saccoLegalName     String
  registrationNumber String   @unique // Statutory registration code issued by the Ministry of Trade, Industry & Cooperatives
  licenseType        String   // "TIER_4_MICROFINANCE", "COMMUNITY_COOP", "DISTRICT_UNION"
  headOfficeAddress  String
  primaryContactEmail String  @unique
  primaryContactPhone String
  
  // 🏦 SETTLEMENT BANKING TRUNK NODE (Where diaspora funding flows are routed)
  settlementBankName String   // e.g., "Stanbic Bank Uganda", "Centenary Bank", "DFCU Bank"
  settlementAccountNo String
  settlementBranch   String
  swiftCode          String?  // Optional SWIFT code routing for international direct wire integrations
  
  status             String   @default("PENDING_VERIFICATION") // "PENDING_VERIFICATION", "ACTIVE", "SUSPENDED"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relational link to aggregate all diaspora funding transits hitting this institution
  remittances        RemittanceLog[]



  @@index([idNumber])
}

// ==========================================
// 📞 VOIP COMMUNICATIONS ARRAY
// ==========================================

model VoipAccount {
  id            String        @id @default(uuid())
  userId        Int           @unique // Linked to User.id (Int)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade) // 🟢 FIXED: Missing relational map added
  virtualNumber String        @unique
  balanceUGX    Float         @default(5000.0)
  tierClass     String        @default("DIASPORA_STANDARD")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  callLogs      VoipCallLog[]
}

model VoipCallLog {
  id            String      @id @default(uuid())
  voipAccountId String
  account       VoipAccount @relation(fields: [voipAccountId], references: [id], onDelete: Cascade)
  destinationNo String
  durationSecs  Int
  costUGX       Float
  status        String      @default("COMPLETED")
  createdAt     DateTime    @default(now())
}
